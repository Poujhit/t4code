{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "t4code",
  "version": "0.0.14",
  "identifier": "com.poujhit.t4code",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devUrl": "http://127.0.0.1:5743",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "t4code",
        "width": 1100,
        "height": 780,
        "minWidth": 840,
        "minHeight": 620,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["../.stage/server-runtime", "../.stage/node-runtime"]
  }
}
